generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  orders    Order[]
  protocol  Protocol?
}

model Product {
  id             String      @id @default(cuid())
  name           String
  slug           String      @unique
  brand          String
  description    String
  price          Float
  category       String
  certifications String[]
  imageUrl       String?
  affiliateUrl   String?
  supplier       String?
  asin           String?
  inStock        Boolean     @default(true)
  createdAt      DateTime    @default(now())
  orderItems     OrderItem[]
}

model Recipe {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  description    String
  prepTime       Int
  servings       Int
  costPerServing Float
  difficulty     String
  // type: what kind of preparation this is — tea, tonic, syrup, paste,
  // smoothie, balm, tincture, oil-blend, bath-soak. Drives the type filter
  // chips on /recipes. Default "tea" so existing rows backfill cleanly when
  // the migration runs before seedRecipes is re-run.
  type           String   @default("tea")
  goals          String[]
  steps          Json
  ingredients    Json
  createdAt      DateTime @default(now())
}

model Protocol {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  name      String
  goals     String[]
  items     Json
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id])
  total     Float
  status    String      @default("pending")
  createdAt DateTime    @default(now())
  items     OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  qty       Int
  price     Float
}